# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/stock_manager

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Market APIs (all free)
FINNHUB_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cron intervals
PRICE_UPDATE_INTERVAL=*/60 * * * *
ALERT_CHECK_INTERVAL=*/60 * * * *
